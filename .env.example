# V3 model config lives in the settings table and is editable in the UI.
# SJTU is OpenAI-compatible, so LiteLLM uses the openai/* provider prefix.
# Default settings rows:
#   model.chat_strong = openai/deepseek-chat
#   model.chat_cheap  = openai/qwen3.5-27b
#   model.steward     = openai/deepseek-chat

OPENAI_API_BASE=https://models.sjtu.edu.cn/api/v1
OPENAI_BASE_URL=https://models.sjtu.edu.cn/api/v1
OPENAI_API_KEY=填入你的_SJTU_API_KEY

# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# If no compatible provider key is present, the app uses the local demo fallback
# so the acceptance flow can run without paid model calls.
# Set this to 1 to force fallback even when API keys exist.
LLM_FORCE_FALLBACK=0
